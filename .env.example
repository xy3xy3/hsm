# OpenAI-compatible API Configuration
# OPENAI_API_KEY is also used for compatible providers
OPENAI_API_KEY=your_openai_compatible_api_key_here

# Optional: custom OpenAI-compatible endpoint, e.g. https://api.openai.com/v1
OPENAI_BASE_URL=

# Optional: override the default model used by HSM
OPENAI_MODEL_NAME=gpt-4o-2024-08-06

# Hugging Face token (required for HSSD model downloads)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
